# ---- TravelMate Admin Backend ----

# Port for this admin backend (must differ from the main app's port).
PORT=5001

# Use the SAME MongoDB connection string as the main TravelMate app
# (copy it from the main project's server/.env) so the admin panel
# reads the same users, rides, coupons and subscriptions.
# New TravelMate Atlas cluster (database: Travelmate):
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@your-cluster.xxxxx.mongodb.net/Travelmate?retryWrites=true&w=majority&appName=TravelMate

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=travelmate@admin

# Secret used to sign admin login tokens — use a long random string
JWT_SECRET=replace_with_a_long_random_string

# Optional: comma-separated list of allowed frontend origins (production)
# CORS_ORIGINS=https://admin.yourdomain.com
